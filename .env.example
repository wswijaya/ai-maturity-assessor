# LLM provider selection
# Options: anthropic | openai | ollama | azure  (default: anthropic)
LLM_PROVIDER=anthropic

# Model override — leave blank to use the provider's default
# anthropic default : claude-opus-4-7
# openai default    : gpt-4o
# ollama default    : llama3.2
# azure             : set to your deployment name (e.g. my-gpt4o-deployment)
LLM_MODEL=

# Base URL — required for ollama or any non-default endpoint
# Ollama example: http://localhost:11434/v1
LLM_BASE_URL=

# API key — used when LLM_PROVIDER=openai or azure
# For anthropic, ANTHROPIC_API_KEY is also accepted (backwards compatible)
LLM_API_KEY=

# Anthropic API key (kept for backwards compatibility)
ANTHROPIC_API_KEY=your_key_here

# Azure OpenAI — required when LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
